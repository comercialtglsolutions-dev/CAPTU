{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "outDir": "./dist-api",
        "rootDir": ".",
        "resolveJsonModule": true,
        "noImplicitAny": false,
        "strictNullChecks": false
    },
    "include": [
        "api/**/*",
        "backend/src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src"
    ]
}